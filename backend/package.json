{
  "name": "civic-compass-backend",
  "version": "1.0.0",
  "description": "CIVIC COMPASS — AI Election Intelligence Assistant Backend",
  "main": "dist/index.js",
  "scripts": {
    "test:unit": "jest --config backend/jest.config.ts --testPathPattern=unit",
    "test:integration": "jest --config backend/jest.config.ts --testPathPattern=integration",
    "test:components": "cd frontend && vitest run",
    "test:e2e": "cd frontend && npx playwright test",
    "test:ai": "jest --config backend/jest.config.ts --testPathPattern=ai-validation",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:components && npm run test:e2e && npm run test:ai",
    "test:coverage": "jest --config backend/jest.config.ts --coverage"
  },
  "dependencies": {
    "@google-cloud/monitoring": "^5.3.2",
    "@google-cloud/secret-manager": "^6.1.2",
    "@google/genai": "^1.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.5",
    "multer": "^1.4.5-lts.1",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^11.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
